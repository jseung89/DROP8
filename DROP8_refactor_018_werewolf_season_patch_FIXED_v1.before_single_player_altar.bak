// DROP 8 Refactor 018 — Werewolf Season
// Windows CMD:
//   node --experimental-strip-types DROP8_refactor_018_werewolf_season_patch_FIXED_v1.ts --dry-run
//   node --experimental-strip-types DROP8_refactor_018_werewolf_season_patch_FIXED_v1.ts
//   node --experimental-strip-types DROP8_refactor_018_werewolf_season_patch_FIXED_v1.ts --rollback "patch_backups\refactor_018_werewolf_season\<timestamp>"
import { copyFileSync, cpSync, existsSync, mkdirSync, readFileSync, readdirSync, renameSync, rmSync, statSync, writeFileSync } from 'node:fs';
import { createHash } from 'node:crypto';
import { dirname, isAbsolute, join, relative, resolve } from 'node:path';
import { fileURLToPath } from 'node:url';
import { gunzipSync } from 'node:zlib';
import { spawnSync } from 'node:child_process';

type PatchHunk={id:string;before:string;after:string;beforeSha256:string;afterSha256:string};
type PatchEntry={path:string;purpose:string;mode:'modify';hunks:PatchHunk[];beforeSha256:string;afterSha256:string}|{path:string;purpose:string;mode:'create';content:string;afterSha256:string};
type Payload={marker:string;entries:PatchEntry[]};
type ManifestFile={path:string;existed:boolean;beforeSha256:string;eol:'LF'|'CRLF'};
type GeneratedManifest={path:string;existed:boolean};
type BackupManifest={patchId:string;patchFile:string;createdAt:string;projectRoot:string;files:ManifestFile[];createdFiles:string[];generatedDirs?:GeneratedManifest[]};

const PATCH_ID='DROP8 Refactor 018 Werewolf Season FIXED v1';
const PATCH_FILE='DROP8_refactor_018_werewolf_season_patch_FIXED_v1.ts';
const BACKUP_NAME='refactor_018_werewolf_season';
const PAYLOAD_B64='';
const payload=JSON.parse(gunzipSync(Buffer.from(PAYLOAD_B64,'base64')).toString('utf8')) as Payload;
const dryRun=process.argv.includes('--dry-run');
const rollbackIndex=process.argv.indexOf('--rollback');
const internalTestMode=process.env.DROP8_PATCH_INTERNAL_TEST_MODE==='1';
const forceFail=process.env.DROP8_PATCH_FORCE_FAIL==='1';
const validationLog:string[]=[];

const MAP_REPORT={
  maps:[
    {id:'small',name:'작은 맵',size:4096,altarCandidates:6,armoryCandidates:6,minDistance:900},
    {id:'large',name:'큰 맵',size:6144,altarCandidates:6,armoryCandidates:6,minDistance:1400},
    {id:'dock8',name:'8번 부두',size:7168,altarCandidates:6,armoryCandidates:6,minDistance:1600},
  ],
  policy:'실외 육지·월드 여백·충돌체·수풀·오토바이·긴급 스폰 거리 검증',
};

function normalize(text:string){return text.replace(/^\uFEFF/,'').replace(/\r\n/g,'\n').replace(/\r/g,'\n');}
function sha256(text:string|Buffer){return createHash('sha256').update(typeof text==='string'?normalize(text):text).digest('hex');}
function count(text:string,needle:string){if(!needle)return 0;let total=0,index=0;while((index=text.indexOf(needle,index))!==-1){total++;index+=needle.length;}return total;}
function readText(path:string){return readFileSync(path,'utf8');}
function safeRelative(path:string){const clean=path.replace(/\\/g,'/');if(!clean||clean.startsWith('/')||clean.includes('../')||clean==='..')throw new Error(`안전하지 않은 상대 경로: ${path}`);return clean;}
function isProjectRoot(dir:string){try{const pkg=JSON.parse(readText(join(dir,'package.json')));return Boolean(pkg?.workspaces)&&existsSync(join(dir,'shared','src','index.ts'))&&existsSync(join(dir,'shared','src','vehicleEffects.ts'))&&existsSync(join(dir,'server','src','rooms','Drop8Room.ts'))&&existsSync(join(dir,'client','src','GameScene.ts'));}catch{return false;}}
function ancestors(start:string){const result:string[]=[];let current=resolve(start);for(let i=0;i<12;i++){if(!result.includes(current))result.push(current);const parent=dirname(current);if(parent===current)break;current=parent;}return result;}
function findRoot(){const scriptDir=dirname(fileURLToPath(import.meta.url));const seeds=[...ancestors(process.cwd()),...ancestors(scriptDir)];const candidates:string[]=[];for(const seed of seeds)for(const candidate of [seed,join(seed,'DROP8_SOURCE'),join(seed,'DROP8_SOURCE_ONLY','DROP8_SOURCE')])if(!candidates.includes(candidate))candidates.push(candidate);for(const candidate of candidates)if(isProjectRoot(candidate))return candidate;for(const seed of [process.cwd(),scriptDir]){try{for(const name of readdirSync(seed)){const child=join(seed,name);if(statSync(child).isDirectory()&&name!=='node_modules'&&name!=='.git'&&isProjectRoot(child))return child;}}catch{/* ignore */}}throw new Error('DROP 8 프로젝트 루트를 찾지 못했습니다. 패치 파일을 프로젝트 루트에 두고 다시 실행하세요.');}
function timestamp(){return new Date().toISOString().replace(/[:.]/g,'-');}
function detectEol(text:string):'LF'|'CRLF'{return text.includes('\r\n')?'CRLF':'LF';}
function withEol(text:string,eol:'LF'|'CRLF'){const normalized=normalize(text);return eol==='CRLF'?normalized.replace(/\n/g,'\r\n'):normalized;}
function atomicWrite(path:string,text:string){mkdirSync(dirname(path),{recursive:true});const token=`${process.pid}-${Date.now()}-${Math.random().toString(16).slice(2)}`;const temp=`${path}.ref018-${token}.tmp`,swap=`${path}.ref018-${token}.swap`;writeFileSync(temp,text,'utf8');let moved=false;try{if(existsSync(path)){renameSync(path,swap);moved=true;}renameSync(temp,path);if(moved)rmSync(swap,{force:true});}catch(error){try{rmSync(temp,{force:true});}catch{/* ignore */}if(moved&&existsSync(swap)){try{rmSync(path,{force:true});renameSync(swap,path);}catch{/* outer rollback */}}throw error;}}
function applyHunks(relativePath:string,text:string,hunks:PatchHunk[]){let current=normalize(text);for(const hunk of hunks){if(sha256(hunk.before)!==hunk.beforeSha256||sha256(hunk.after)!==hunk.afterSha256)throw new Error(`${relativePath}: 내장 hunk 무결성 실패 (${hunk.id})`);const matches=count(current,hunk.before);if(matches!==1)throw new Error(`${relativePath}: 분석 당시 코드 블록을 정확히 찾지 못했습니다 (${hunk.id}, 일치 ${matches}개). 수동 변경 충돌이므로 아무 파일도 수정하지 않습니다.`);current=current.replace(hunk.before,hunk.after);}return current;}
function duplicateNamedImports(text:string,file:string){const imported=new Map<string,string>();const pattern=/import\s+(?:type\s+)?\{([\s\S]*?)\}\s+from\s+['"][^'"]+['"]/g;for(const match of text.matchAll(pattern))for(const raw of match[1].split(',')){const item=raw.trim();if(!item)continue;const clean=item.replace(/^type\s+/,'');const parts=clean.split(/\s+as\s+/);const local=(parts[1]??parts[0]).trim();if(!local)continue;if(imported.has(local))throw new Error(`${file}: named import '${local}' 중복`);imported.set(local,item);}}
function classDecoratorCount(source:string,className:string){const start=source.indexOf(`export class ${className}`);if(start<0)return-1;const next=source.indexOf('export class ',start+13);const body=source.slice(start,next<0?source.length:next);return (body.match(/@type\(/g)??[]).length;}
function assertCount(source:string,needle:string,expected:number,file:string){const actual=count(source,needle);if(actual!==expected)throw new Error(`${file}: '${needle}' 개수 ${actual} (예상 ${expected})`);}
function visitSourceFiles(dir:string,callback:(path:string,source:string)=>void){for(const name of readdirSync(dir)){const path=join(dir,name),stat=statSync(path);if(stat.isDirectory())visitSourceFiles(path,callback);else if(/\.(?:ts|tsx|js|jsx)$/.test(name))callback(path,readText(path));}}
function validateNoRefactor016(root:string){const activeRoots=[join(root,'shared','src'),join(root,'server','src'),join(root,'client','src')];const forbidden=['DROP8_REFACTOR_016','DROP8_PLAYER_SYNC_HOTFIX_016B','DROP8_REFACTOR_016C'];for(const dir of activeRoots)visitSourceFiles(dir,(path,source)=>{for(const token of forbidden)if(source.includes(token))throw new Error(`Refactor 016 활성 잔재 감지: ${relative(root,path)} -> ${token}`);});}
function parsePackageScripts(root:string){const pkg=JSON.parse(readText(join(root,'package.json')));const scripts=pkg?.scripts??{};for(const name of ['typecheck','lint','test','build'])if(typeof scripts[name]!=='string')throw new Error(`package.json에 필수 스크립트가 없습니다: ${name}`);return scripts as Record<string,string>;}
function captureBalances(root:string){const source=normalize(readText(join(root,'shared','src','index.ts')));const requirePattern=(label:string,pattern:RegExp)=>{if(!pattern.test(source))throw new Error(`현재 수동 밸런스 보존 검증 실패: ${label}`);};requirePattern('권총 피해 18',/pistol:\{[^}]*damage:18[,}]/s);requirePattern('기관단총 피해 11',/smg:\{[^}]*damage:11[,}]/s);requirePattern('소총 피해 17',/rifle:\{[^}]*damage:17[,}]/s);requirePattern('산탄총 피해 10',/shotgun:\{[^}]*damage:10[,}]/s);requirePattern('저격총 피해 72',/sniper:\{[^}]*damage:72[,}]/s);requirePattern('바주카포 탄속 900',/bazooka:\{[^}]*projectileSpeed:900[,}]/s);requirePattern('화염방사기 사거리 420·피해 9',/flamethrower:\{[^}]*damage:9[^}]*range:420[,}]/s);requirePattern('보급 단계·가중치',/SUPPLY_DROP_BALANCE=\{[^}]*triggerZoneStage:0[^}]*bazookaWeight:0,flamethrowerWeight:100/s);requirePattern('화염 틱 9\/6\/1',/FLAMETHROWER_BALANCE=\{[^}]*playerDamagePerTick:9,vehicleDamagePerTick:6,fuelPerTick:1/s);requirePattern('바주카포 수치',/BAZOOKA_BALANCE=\{[^}]*maxPlayerDamage:112[^}]*directVehicleDamage:170,maxSplashVehicleDamage:128,minSplashVehicleDamage:14[^}]*structureDamage:120/s);requirePattern('오토바이 launch 1.05',/launchSpeedMultiplier:1\.05[,}]/);requirePattern('오토바이 max 1.85',/maxSpeedMultiplier:1\.85[,}]/);requirePattern('오토바이 가속 시간 2400',/timeToMaxSpeedMs:2400[,}]/);requirePattern('오토바이 정지 시간 480',/releaseStopTimeMs:480[,}]/);requirePattern('오토바이 충돌 피해 45',/maxCollisionDamage:45[,}]/);requirePattern('오토바이 HP 180',/MOTORCYCLE_DESTRUCTION_BALANCE\s*=\s*\{[^}]*maxHp:180/s);requirePattern('오토바이 직접 가속 900',/MOTORCYCLE_DIRECT_ACCELERATION\s*=\s*900/);return{guns:'18 / 11 / 17 / 10×7 / 72',bazooka:'탄속 900 · 플레이어 112 · 차량 170/128/14 · 구조물 120',flamethrower:'사거리 420 · 틱 9/6 · 연료 1',supply:'단계 0 · 바주카 0 · 화염방사기 100',motorcycle:'최고속도 481 · HP 180 · 충돌 최대 45 · 가속 900'};}
function validateBaseline(root:string){const shared=normalize(readText(join(root,'shared/src/index.ts'))),room=normalize(readText(join(root,'server/src/rooms/Drop8Room.ts'))),schema=normalize(readText(join(root,'server/src/rooms/schema.ts'))),types=normalize(readText(join(root,'shared/src/maps/types.ts'))),dock=normalize(readText(join(root,'shared/src/maps/dock8.ts')));if(!shared.includes('DROP8_REFACTOR_017_ADHESIVE_STRIP_LOBBY_BAZOOKA_WATER')||!room.includes('DROP8_REFACTOR_017_ADHESIVE_STRIP_LOBBY_BAZOOKA_WATER')||!schema.includes('DROP8_REFACTOR_017_ADHESIVE_STRIP_LOBBY_BAZOOKA_WATER'))throw new Error('현재 안정 기준 Refactor 017 표식을 찾지 못했습니다. 최신 ZIP 기준이 아닙니다.');if(!types.includes("export type MapId='small'|'large'|'dock8'"))throw new Error('맵 ID 기준 검증 실패');if(!shared.includes('SMALL_WORLD_SIZE = 4096')||!shared.includes('LARGE_WORLD_SIZE = 6144')||!dock.includes('DOCK8_WORLD_SIZE=7168'))throw new Error('맵 크기 기준 검증 실패');const playerFields=classDecoratorCount(schema,'PlayerState'),stateFields=classDecoratorCount(schema,'Drop8State');if(playerFields!==63||stateFields!==63)throw new Error(`Refactor 018 적용 전 Schema 기준 불일치: Player=${playerFields}, State=${stateFields} (예상 63/63)`);}
function validatePatchedContent(root:string){for(const entry of payload.entries){const path=join(root,safeRelative(entry.path));if(!existsSync(path))throw new Error(`변경 후 필수 파일 누락: ${entry.path}`);const source=normalize(readText(path));if(!source.includes(payload.marker))throw new Error(`변경 후 패치 표식 누락: ${entry.path}`);if(entry.mode==='create'){if(sha256(source)!==entry.afterSha256)throw new Error(`변경 후 신규 파일 내용 검증 실패: ${entry.path}`);}else for(const hunk of entry.hunks)if(count(source,hunk.after)!==1)throw new Error(`변경 후 구조 블록 검증 실패: ${entry.path} (${hunk.id})`);if(entry.path.endsWith('.ts'))duplicateNamedImports(source,entry.path);}const shared=normalize(readText(join(root,'shared/src/index.ts'))),wolf=normalize(readText(join(root,'shared/src/werewolfSeason.ts'))),vehicle=normalize(readText(join(root,'shared/src/vehicleEffects.ts'))),schema=normalize(readText(join(root,'server/src/rooms/schema.ts'))),room=normalize(readText(join(root,'server/src/rooms/Drop8Room.ts'))),client=normalize(readText(join(root,'client/src/GameScene.ts'))),network=normalize(readText(join(root,'client/src/network.ts'))),main=normalize(readText(join(root,'client/src/main.ts')));assertCount(shared,"silver_crossbow:{ id:'silver_crossbow'",1,'shared/src/index.ts');assertCount(shared,"'silver_bolt'",5,'shared/src/index.ts');assertCount(vehicle,"'werewolf_hunt'",1,'shared/src/vehicleEffects.ts');assertCount(schema,'export class WerewolfPlayerState',1,'server/src/rooms/schema.ts');assertCount(schema,'export class WerewolfSeasonState',1,'server/src/rooms/schema.ts');assertCount(room,"this.onMessage('werewolfRitualStart'",1,'server/src/rooms/Drop8Room.ts');assertCount(room,"this.onMessage('werewolfTransform'",1,'server/src/rooms/Drop8Room.ts');assertCount(room,'private updateWerewolfSeason',1,'server/src/rooms/Drop8Room.ts');assertCount(room,'private werewolfClaw',1,'server/src/rooms/Drop8Room.ts');const playerFields=classDecoratorCount(schema,'PlayerState'),stateFields=classDecoratorCount(schema,'Drop8State');if(playerFields!==64||stateFields!==64)throw new Error(`Colyseus Schema 필드 검증 실패: Player=${playerFields}, State=${stateFields} (예상 64/64)`);if(!schema.includes('@type(WerewolfPlayerState) werewolf=new WerewolfPlayerState()')||!schema.includes('@type(WerewolfSeasonState) werewolfSeason=new WerewolfSeasonState()'))throw new Error('중첩 늑대 Schema 연결 실패');if(!wolf.includes('small:[')||!wolf.includes('large:[')||!wolf.includes('dock8:[')||!wolf.includes('initialSilverBolts:5'))throw new Error('세 맵 후보 또는 은화살 보급 기준 누락');if(!room.includes("applyVehicleSlow(vehicle,'werewolf_hunt'")||!room.includes("b.weaponId==='silver_crossbow'&&hitPlayer.werewolf.transformed"))throw new Error('늑대 차량 사냥 또는 은화살 특수 피해 연결 실패');if(!client.includes("this.net.send('werewolfRitualStart'")||!client.includes("this.net.send('werewolfTransform'")||!client.includes('MOTORCYCLE_MAX_TURN_RATE*3.1'))throw new Error('클라이언트 의식·변신·질주 예측 연결 실패');if(!network.includes('werewolfSeason')||!main.includes("$('werewolfHud')"))throw new Error('네트워크·HUD 동기화 연결 실패');captureBalances(root);}
function patchMarkerState(root:string){let applied=0,before=0;const conflicts:string[]=[];for(const entry of payload.entries){const path=join(root,safeRelative(entry.path));if(entry.mode==='modify'){if(!existsSync(path)){conflicts.push(`${entry.path}(누락)`);continue;}const source=normalize(readText(path));if(source.includes(payload.marker))applied++;else before++;}else{if(!existsSync(path))before++;else if(normalize(readText(path)).includes(payload.marker))applied++;else conflicts.push(`${entry.path}(동명 파일 충돌)`);}}return{applied,before,conflicts,total:payload.entries.length};}
function ensureNoPreexistingFeatureCollision(root:string){const checks:[string,string][]=[['shared/src/index.ts',"'silver_crossbow'"],['server/src/rooms/schema.ts','class WerewolfPlayerState'],['server/src/rooms/Drop8Room.ts',"onMessage('werewolfRitualStart'"],['client/src/GameScene.ts',"werewolfTransform"]];for(const [file,needle] of checks)if(readText(join(root,file)).includes(needle))throw new Error(`패치 표식 없는 기존 기능 충돌: ${file} -> ${needle}`);}
function prepareOutputs(root:string){const outputs=new Map<string,{text:string;eol:'LF'|'CRLF';existed:boolean}>();for(const entry of payload.entries){const rel=safeRelative(entry.path),target=join(root,rel);if(entry.mode==='modify'){const original=readText(target),eol=detectEol(original),patched=applyHunks(rel,original,entry.hunks);outputs.set(rel,{text:withEol(patched,eol),eol,existed:true});}else{if(existsSync(target))throw new Error(`신규 파일이 이미 존재합니다: ${rel}`);if(sha256(entry.content)!==entry.afterSha256)throw new Error(`${rel}: 내장 신규 파일 무결성 실패`);outputs.set(rel,{text:entry.content,eol:'LF',existed:false});}}return outputs;}
function rollbackBackup(root:string,backupArg:string){const backup=isAbsolute(backupArg)?backupArg:resolve(root,backupArg),manifestPath=join(backup,'manifest.json');if(!existsSync(manifestPath))throw new Error(`롤백 manifest를 찾지 못했습니다: ${manifestPath}`);const manifest=JSON.parse(readText(manifestPath)) as BackupManifest;if(manifest.patchId!==PATCH_ID)throw new Error(`다른 패치의 백업입니다: ${manifest.patchId}`);for(const item of [...manifest.files].reverse()){const target=join(root,safeRelative(item.path)),source=join(backup,'preimage',safeRelative(item.path));if(item.existed){if(!existsSync(source))throw new Error(`백업 원본 누락: ${item.path}`);atomicWrite(target,readText(source));}else rmSync(target,{force:true});}for(const item of manifest.generatedDirs??[]){const target=join(root,safeRelative(item.path)),source=join(backup,'generated-preimage',safeRelative(item.path));rmSync(target,{recursive:true,force:true});if(item.existed){if(!existsSync(source))throw new Error(`생성물 백업 누락: ${item.path}`);mkdirSync(dirname(target),{recursive:true});cpSync(source,target,{recursive:true,preserveTimestamps:true});}}console.log(`[${PATCH_ID}] 롤백 완료: ${backup}`);}
function runCommand(label:string,command:string,root:string,logPath:string){console.log(`\n[${PATCH_ID}] ${label}\n> ${command}`);const result=spawnSync(command,{cwd:root,shell:true,encoding:'utf8',env:process.env,maxBuffer:64*1024*1024});const output=`\n### ${label}\n> ${command}\nexit=${result.status}\n${result.stdout??''}\n${result.stderr??''}\n`;validationLog.push(output);if(result.stdout)process.stdout.write(result.stdout);if(result.stderr)process.stderr.write(result.stderr);writeFileSync(logPath,validationLog.join(''),'utf8');if(result.error)throw result.error;if(result.status!==0)throw new Error(`${label} 실패 (exit=${result.status})`);}
function probeCommand(command:string,root:string){const result=spawnSync(command,{cwd:root,shell:true,encoding:'utf8',env:process.env,maxBuffer:16*1024*1024});return{ok:result.status===0,output:`${result.stdout??''}${result.stderr??''}`};}

const root=findRoot();process.chdir(root);console.log(`[${PATCH_ID}] 프로젝트 루트: ${root}`);
if(rollbackIndex>=0){const backupArg=process.argv[rollbackIndex+1];if(!backupArg)throw new Error('--rollback 뒤에 백업 폴더를 입력하세요.');rollbackBackup(root,backupArg);process.exit(0);}
parsePackageScripts(root);validateNoRefactor016(root);const markerState=patchMarkerState(root);if(markerState.conflicts.length)throw new Error(`파일 충돌: ${markerState.conflicts.join(', ')}`);
if(markerState.applied===markerState.total){validatePatchedContent(root);const balances=captureBalances(root);console.log(`[${PATCH_ID}] 현재 총기 피해: ${balances.guns}`);console.log(`[${PATCH_ID}] 화염방사기: ${balances.flamethrower}`);console.log(`[${PATCH_ID}] 바주카포: ${balances.bazooka}`);console.log(`[${PATCH_ID}] 오토바이: ${balances.motorcycle}`);console.log(`[${PATCH_ID}] 이미 정상 적용되어 있습니다.`);process.exit(0);}
if(markerState.applied>0)throw new Error(`부분 적용 상태 감지: ${markerState.applied}/${markerState.total}개 파일에 패치 표식이 있습니다. 나머지만 억지로 적용하지 않습니다.`);
validateBaseline(root);const balances=captureBalances(root);ensureNoPreexistingFeatureCollision(root);const outputs=prepareOutputs(root);
console.log(`[${PATCH_ID}] 현재 총기 피해: ${balances.guns}`);console.log(`[${PATCH_ID}] 화염방사기: ${balances.flamethrower}`);console.log(`[${PATCH_ID}] 바주카포: ${balances.bazooka}`);console.log(`[${PATCH_ID}] 보급: ${balances.supply}`);console.log(`[${PATCH_ID}] 오토바이: ${balances.motorcycle}`);
console.log(`[${PATCH_ID}] 적용 전 Schema: PlayerState 63 / Drop8State 63`);console.log(`[${PATCH_ID}] 감지 맵: small(4096) · large(6144) · dock8(7168)`);for(const map of MAP_REPORT.maps)console.log(`[${PATCH_ID}] ${map.name}: 제단 ${map.altarCandidates}곳 · 무기함 ${map.armoryCandidates}곳 · 최소 거리 ${map.minDistance}px`);
const expectedBackup=join(root,'patch_backups',BACKUP_NAME,'<timestamp>');console.log(`\n[${PATCH_ID}] 적용 상태: 미적용`);console.log(`[${PATCH_ID}] 늑대 제단·저주·30초 변신: 신규 적용 예정`);console.log(`[${PATCH_ID}] 질주·할퀴기·오토바이 2단계 사냥: 신규 적용 예정`);console.log(`[${PATCH_ID}] 은빛 무기함·은화살 쇠뇌: 신규 적용 예정`);console.log(`[${PATCH_ID}] 10초 제단 재충전·은화살 제한 보충: 신규 적용 예정`);console.log(`\n[${PATCH_ID}] 변경 예정 파일:`);for(const entry of payload.entries)console.log(` - ${entry.mode==='create'?'[신규]':'[수정]'} ${entry.path} :: ${entry.purpose}`);console.log(`[${PATCH_ID}] 예상 백업 위치: ${expectedBackup}`);console.log(`[${PATCH_ID}] 실행 예정 검증: typecheck -> lint -> Refactor 018 신규/영향 테스트 -> 전체 test -> build -> git diff --check`);if(dryRun){console.log(`\n[${PATCH_ID}] dry-run 성공: 실제 파일·백업을 생성하지 않았습니다.`);process.exit(0);}

const backupRoot=join(root,'patch_backups',BACKUP_NAME,timestamp()),preimageRoot=join(backupRoot,'preimage');mkdirSync(preimageRoot,{recursive:true});const manifestFiles:ManifestFile[]=[];const createdFiles:string[]=[];for(const [rel,output] of outputs){const target=join(root,rel),backup=join(preimageRoot,rel);if(output.existed){mkdirSync(dirname(backup),{recursive:true});copyFileSync(target,backup);manifestFiles.push({path:rel,existed:true,beforeSha256:sha256(readFileSync(target)),eol:output.eol});}else{createdFiles.push(rel);manifestFiles.push({path:rel,existed:false,beforeSha256:'',eol:'LF'});}}
const generatedDirs:GeneratedManifest[]=[];for(const rel of ['shared/dist','client/dist','server/build']){const target=join(root,rel),existed=existsSync(target);generatedDirs.push({path:rel,existed});if(existed){const backup=join(backupRoot,'generated-preimage',rel);mkdirSync(dirname(backup),{recursive:true});cpSync(target,backup,{recursive:true,preserveTimestamps:true});}}
const manifest:BackupManifest={patchId:PATCH_ID,patchFile:PATCH_FILE,createdAt:new Date().toISOString(),projectRoot:root,files:manifestFiles,createdFiles,generatedDirs};writeFileSync(join(backupRoot,'manifest.json'),JSON.stringify(manifest,null,2),'utf8');writeFileSync(join(backupRoot,'created-files.json'),JSON.stringify(createdFiles,null,2),'utf8');writeFileSync(join(backupRoot,'balance-snapshot.json'),JSON.stringify(balances,null,2),'utf8');writeFileSync(join(backupRoot,'map-candidate-report.json'),JSON.stringify(MAP_REPORT,null,2),'utf8');const validationLogPath=join(backupRoot,'verification-log.txt');writeFileSync(validationLogPath,'','utf8');const baselineDiff=probeCommand('git diff --check',root);
try{for(const [rel,output] of outputs)atomicWrite(join(root,rel),output.text);validatePatchedContent(root);if(forceFail)throw new Error('DROP8_PATCH_FORCE_FAIL=1 강제 롤백 시험');if(internalTestMode)console.log(`[${PATCH_ID}] 내부 복제본 시험 모드: 외부 pnpm 검증 생략`);else{runCommand('TypeScript typecheck','pnpm run typecheck',root,validationLogPath);runCommand('ESLint','pnpm run lint',root,validationLogPath);runCommand('공용 Refactor 018 테스트','pnpm --filter @drop8/shared exec vitest run tests/refactor018-werewolf-season.test.ts tests/refactor018-werewolf-map-candidates.test.ts tests/rules.test.ts --reporter=verbose',root,validationLogPath);runCommand('서버 Refactor 018·Room 영향 테스트','pnpm --filter @drop8/server exec vitest run tests/refactor018-werewolf-ritual-transform.test.ts tests/refactor018-werewolf-combat.test.ts tests/refactor018-silver-crossbow.test.ts tests/refactor018-werewolf-recharge-cleanup.test.ts tests/refactor018-werewolf-schema-sync.test.ts tests/room.test.ts --pool=threads --maxWorkers=1 --no-file-parallelism --testTimeout=30000 --hookTimeout=30000 --reporter=verbose',root,validationLogPath);runCommand('전체 테스트','pnpm run test',root,validationLogPath);runCommand('전체 빌드','pnpm run build',root,validationLogPath);if(baselineDiff.ok)runCommand('git diff --check','git diff --check',root,validationLogPath);else{console.warn(`[${PATCH_ID}] 적용 전부터 전체 git diff --check 경고가 있어 Refactor 018 대상 파일만 검사합니다.`);validationLog.push(`\n### 적용 전 git diff --check 기존 경고\n${baselineDiff.output}\n`);const paths=payload.entries.map((entry)=>`"${entry.path}"`).join(' ');runCommand('Refactor 018 대상 git diff --check',`git diff --check -- ${paths}`,root,validationLogPath);}}
console.log(`\n[${PATCH_ID}] 적용과 검증이 성공했습니다.`);console.log(`[${PATCH_ID}] 백업: ${backupRoot}`);console.log(`[${PATCH_ID}] 롤백: node --experimental-strip-types ${PATCH_FILE} --rollback "${relative(root,backupRoot)}"`);
}catch(error){console.error(`\n[${PATCH_ID}] 실패 감지. Refactor 018 변경 전체를 자동 롤백합니다.`);try{rollbackBackup(root,backupRoot);}catch(rollbackError){console.error(`[${PATCH_ID}] 자동 롤백 중 오류`,rollbackError);}console.error(`[${PATCH_ID}] 백업 위치: ${backupRoot}`);throw error;}
